#!/usr/bin/env bash
# qsassets — appliance management CLI
#
# Usage:
#   qsassets status                     Show service + container status
#   qsassets logs [service] [-f]       Tail logs (api|web|postgres|redis|caddy)
#   qsassets backup [dir]              Dump Postgres + config to a tar.gz
#   qsassets restore <backup.tar.gz>   Restore a backup (stops stack first)
#   qsassets upgrade <bundle-dir|tgz>  Upgrade from a release bundle
#   qsassets uninstall [--purge]       Remove the appliance (--purge drops data)
#   qsassets support-bundle [dir]      Collect redacted diagnostics for support

set -euo pipefail

INSTALL_DIR="/opt/qsassets"
ENV_FILE="/etc/qsassets/qsassets.env"
COMPOSE_FILE="${INSTALL_DIR}/docker-compose.appliance.yml"
UNIT="qsassets.service"
BACKUP_DIR_DEFAULT="/var/lib/qsassets/backups"
DB_CONTAINER="qsassets-db"

log()  { printf '\033[1;32m[qsassets]\033[0m %s\n' "$*"; }
warn() { printf '\033[1;33m[qsassets] WARN:\033[0m %s\n' "$*" >&2; }
die()  { printf '\033[1;31m[qsassets] ERROR:\033[0m %s\n' "$*" >&2; exit 1; }

need_root() { [ "$(id -u)" -eq 0 ] || die "Run as root (sudo qsassets $*)."; }
compose() { docker compose --env-file "$ENV_FILE" -f "$COMPOSE_FILE" "$@"; }

# Temp-dir bookkeeping: one EXIT trap, every mktemp_dir gets cleaned up.
CLEANUP_DIRS=""
trap '[ -n "$CLEANUP_DIRS" ] && rm -rf $CLEANUP_DIRS' EXIT
mktemp_dir() { local d; d="$(mktemp -d)"; CLEANUP_DIRS="$CLEANUP_DIRS $d"; echo "$d"; }

usage() { sed -n '2,12p' "$0" | sed 's/^# \{0,1\}//'; exit "${1:-0}"; }

cmd_status() {
  echo "systemd:"
  systemctl status "$UNIT" --no-pager --lines=0 2>/dev/null || warn "unit not loaded"
  echo
  echo "containers:"
  compose ps
  echo
  echo "api health:"
  curl -fsSk https://127.0.0.1/api/v1/health 2>/dev/null \
    || curl -fsS http://127.0.0.1:4100/api/v1/health 2>/dev/null \
    || echo "  unreachable"
  echo
}

cmd_logs() {
  local svc="" follow=""
  while [ $# -gt 0 ]; do
    case "$1" in
      -f|--follow) follow="-f" ;;
      *) svc="$1" ;;
    esac
    shift
  done
  # shellcheck disable=SC2086
  compose logs --tail=200 $follow $svc
}

cmd_backup() {
  need_root backup
  local out_dir="${1:-$BACKUP_DIR_DEFAULT}"
  local ts stamp work
  ts="$(date +%Y%m%d_%H%M%S)"
  stamp="qsassets-backup-${ts}"
  work="$(mktemp_dir)"
  mkdir -p "$out_dir"

  log "Dumping database ..."
  docker exec "$DB_CONTAINER" pg_dump -U postgres --format=custom assetcommand \
    > "${work}/assetcommand.dump"

  log "Copying configuration ..."
  cp "$ENV_FILE" "${work}/qsassets.env"
  cp "$COMPOSE_FILE" "${work}/" 2>/dev/null || true
  cp "${INSTALL_DIR}/Caddyfile" "${work}/" 2>/dev/null || true
  cat > "${work}/manifest.json" <<EOF
{"created":"$(date -u +%Y-%m-%dT%H:%M:%SZ)","host":"$(hostname)","type":"qsassets-appliance-backup","version":1}
EOF

  local archive="${out_dir}/${stamp}.tar.gz"
  tar -C "$work" -czf "$archive" .
  chmod 600 "$archive"
  log "Backup written: ${archive}"
  log "This archive contains secrets (qsassets.env) — store it securely."
}

cmd_restore() {
  need_root restore
  local archive="${1:-}"
  [ -n "$archive" ] && [ -f "$archive" ] || die "Usage: qsassets restore <backup.tar.gz>"
  local work
  work="$(mktemp_dir)"
  tar -C "$work" -xzf "$archive"
  [ -f "${work}/assetcommand.dump" ] || die "Archive has no assetcommand.dump — not a qsassets backup."

  warn "This will REPLACE the current database and configuration."
  read -r -p "Type 'restore' to continue: " reply
  [ "$reply" = "restore" ] || die "Aborted."

  log "Stopping application containers (keeping postgres) ..."
  compose stop api web caddy || true
  compose up -d postgres
  until docker exec "$DB_CONTAINER" pg_isready -U postgres >/dev/null 2>&1; do sleep 2; done

  if [ -f "${work}/qsassets.env" ]; then
    install -m 600 "${work}/qsassets.env" "$ENV_FILE"
    log "Restored ${ENV_FILE}"
  fi

  log "Restoring database (drop + recreate) ..."
  docker exec "$DB_CONTAINER" psql -U postgres -c \
    "SELECT pg_terminate_backend(pid) FROM pg_stat_activity WHERE datname='assetcommand' AND pid<>pg_backend_pid();" >/dev/null
  docker exec "$DB_CONTAINER" dropdb -U postgres --if-exists assetcommand
  docker exec "$DB_CONTAINER" createdb -U postgres assetcommand
  docker exec -i "$DB_CONTAINER" pg_restore -U postgres -d assetcommand --no-owner \
    < "${work}/assetcommand.dump"

  log "Starting the stack ..."
  compose up -d
  log "Restore complete."
}

verify_bundle_sums() {
  # verify_bundle_sums <dir> — verifies SHA256SUMS if present; 0 = ok/absent
  local dir="$1"
  if [ ! -f "${dir}/SHA256SUMS" ]; then
    warn "No SHA256SUMS in bundle — skipping integrity verification."
    return 0
  fi
  log "Verifying bundle integrity (SHA256SUMS) ..."
  if command -v sha256sum >/dev/null 2>&1; then
    (cd "$dir" && sha256sum --check --strict SHA256SUMS)
  else
    (cd "$dir" && shasum -a 256 --check --strict SHA256SUMS)
  fi
}

cmd_upgrade() {
  need_root upgrade
  local src="${1:-}"
  [ -n "$src" ] || die "Usage: qsassets upgrade <bundle-dir | bundle.tar.gz>"

  local bundle_dir work=""
  if [ -f "$src" ]; then
    work="$(mktemp_dir)"
    tar -C "$work" -xzf "$src"
    # tolerate a single wrapping directory in the tarball
    bundle_dir="$work"
    if [ ! -f "${bundle_dir}/docker-compose.appliance.yml" ]; then
      bundle_dir="$(find "$work" -maxdepth 2 -name docker-compose.appliance.yml -exec dirname {} \; | head -1)"
    fi
  elif [ -d "$src" ]; then
    bundle_dir="$src"
  else
    die "No such file or directory: $src"
  fi
  [ -n "$bundle_dir" ] && [ -f "${bundle_dir}/docker-compose.appliance.yml" ] \
    || die "Not a qsassets appliance bundle (docker-compose.appliance.yml missing)."

  verify_bundle_sums "$bundle_dir" || die "SHA256SUMS verification FAILED — refusing to upgrade."

  log "Backing up before upgrade ..."
  cmd_backup

  log "Loading new container images (if bundled) ..."
  if [ -d "${bundle_dir}/images" ]; then
    for img in "${bundle_dir}/images"/*.tar "${bundle_dir}/images"/*.tar.gz "${bundle_dir}/images"/*.tar.zst; do
      [ -e "$img" ] || continue
      log "  docker load $(basename "$img")"
      case "$img" in
        *.tar.zst) zstd -dc "$img" | docker load ;;
        *.tar.gz)  gzip -dc "$img" | docker load ;;
        *)         docker load -i "$img" ;;
      esac
    done
  fi

  log "Installing updated files ..."
  install -m 644 "${bundle_dir}/docker-compose.appliance.yml" "$COMPOSE_FILE"
  [ -f "${bundle_dir}/Caddyfile" ] && install -m 644 "${bundle_dir}/Caddyfile" "${INSTALL_DIR}/Caddyfile"
  [ -f "${bundle_dir}/init-extensions.sql" ] && install -m 644 "${bundle_dir}/init-extensions.sql" "${INSTALL_DIR}/init-extensions.sql"
  [ -f "${bundle_dir}/qsassets.service" ] && install -m 644 "${bundle_dir}/qsassets.service" /etc/systemd/system/qsassets.service && systemctl daemon-reload
  if [ -f "${bundle_dir}/qsassets" ]; then
    install -m 755 "${bundle_dir}/qsassets" "${INSTALL_DIR}/qsassets.new"
    mv "${INSTALL_DIR}/qsassets.new" "${INSTALL_DIR}/qsassets"
  fi
  if [ -f "${bundle_dir}/manifest.json" ]; then
    install -m 644 "${bundle_dir}/manifest.json" "${INSTALL_DIR}/manifest.json"
    local ver
    ver="$(sed -n 's/.*"version"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' "${bundle_dir}/manifest.json" | head -1)"
    if [ -n "$ver" ]; then
      log "Bundle version: ${ver}"
      if grep -q '^QSASSETS_VERSION=' "$ENV_FILE"; then
        sed -i "s/^QSASSETS_VERSION=.*/QSASSETS_VERSION=${ver}/" "$ENV_FILE"
      else
        echo "QSASSETS_VERSION=${ver}" >> "$ENV_FILE"
      fi
    fi
  fi

  log "Restarting the stack with the new version ..."
  compose up -d --no-build --remove-orphans || compose up -d --build --remove-orphans
  log "Upgrade complete. Check: qsassets status"
}

cmd_uninstall() {
  need_root uninstall
  local purge=0
  [ "${1:-}" = "--purge" ] && purge=1

  warn "This will stop and remove the QS Assets appliance."
  [ "$purge" = "1" ] && warn "--purge will ALSO DELETE the database and all volumes."
  read -r -p "Type 'uninstall' to continue: " reply
  [ "$reply" = "uninstall" ] || die "Aborted."

  systemctl disable --now "$UNIT" 2>/dev/null || true
  if [ "$purge" = "1" ]; then
    compose down --volumes --remove-orphans || true
  else
    compose down --remove-orphans || true
  fi
  rm -f "/etc/systemd/system/${UNIT}"
  systemctl daemon-reload
  rm -f /usr/local/bin/qsassets
  rm -rf "$INSTALL_DIR"
  if [ "$purge" = "1" ]; then
    rm -rf /etc/qsassets
    log "Uninstalled and purged all data."
  else
    log "Uninstalled. Data volumes and /etc/qsassets/qsassets.env were kept."
    log "Purge later with: docker volume rm qsassets_pgdata qsassets_redisdata"
  fi
}

cmd_support_bundle() {
  need_root support-bundle
  local out_dir="${1:-/tmp}"
  local ts work
  ts="$(date +%Y%m%d_%H%M%S)"
  work="$(mktemp_dir)"

  log "Collecting diagnostics ..."
  {
    echo "== date ==";        date -u
    echo "== uname ==";       uname -a
    echo "== memory ==";      free -h 2>/dev/null || true
    echo "== disk ==";        df -h /opt /var/lib/docker 2>/dev/null || true
    echo "== docker ==";      docker version 2>&1 || true
    echo "== compose ps =="   ; compose ps 2>&1 || true
  } > "${work}/system.txt"

  systemctl status "$UNIT" --no-pager > "${work}/systemd.txt" 2>&1 || true
  journalctl -u "$UNIT" --no-pager -n 500 > "${work}/journal.txt" 2>&1 || true

  local svc
  for svc in api web postgres redis caddy; do
    compose logs --tail=1000 "$svc" > "${work}/logs-${svc}.txt" 2>&1 || true
  done

  # Config with every secret-looking value redacted.
  if [ -f "$ENV_FILE" ]; then
    sed -E 's/^((DB_PASSWORD|DATABASE_URL|REDIS_URL|JWT_SECRET|JWT_REFRESH_SECRET|VAULT_ENCRYPTION_KEY|OWNER_PASSWORD|TENANT_ADMIN_PASSWORD|LICENSE_[A-Z_]*)=).*/\1<redacted>/' \
      "$ENV_FILE" > "${work}/qsassets.env.redacted"
  fi
  cp "$COMPOSE_FILE" "${work}/" 2>/dev/null || true
  cp "${INSTALL_DIR}/Caddyfile" "${work}/" 2>/dev/null || true
  cp "${INSTALL_DIR}/manifest.json" "${work}/" 2>/dev/null || true

  local archive="${out_dir}/qsassets-support-${ts}.tar.gz"
  tar -C "$work" -czf "$archive" .
  log "Support bundle: ${archive}"
  log "Secrets are redacted, but review before sharing externally."
}

# ---------------------------------------------------------------------------
main() {
  local cmd="${1:-}"
  shift || true
  case "$cmd" in
    status)          cmd_status "$@" ;;
    logs)            cmd_logs "$@" ;;
    backup)          cmd_backup "$@" ;;
    restore)         cmd_restore "$@" ;;
    upgrade)         cmd_upgrade "$@" ;;
    uninstall)       cmd_uninstall "$@" ;;
    support-bundle)  cmd_support_bundle "$@" ;;
    -h|--help|help|"") usage 0 ;;
    *) warn "Unknown command: $cmd"; usage 1 ;;
  esac
}
main "$@"
