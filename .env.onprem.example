# Example env for customer on-prem / BYO cloud (copy to .env next to docker-compose.prod.yml)

SERVER_IP=192.168.1.50
DEPLOYMENT_MODE=onprem
DISABLE_PUBLIC_SIGNUP=true

# Bundled DB (default) — leave EXTERNAL_* empty and use:
#   docker compose -f docker-compose.prod.yml --profile bundled up -d --build
DB_PASSWORD=change-me-strong

# OR bring your own Postgres / Redis:
# EXTERNAL_DATABASE_URL=postgresql://qs:secret@db.internal:5432/qsassets?schema=public
# EXTERNAL_REDIS_URL=redis://redis.internal:6379
# Then: docker compose -f docker-compose.prod.yml --profile byo up -d --build api web

JWT_SECRET=change-me-jwt
JWT_REFRESH_SECRET=change-me-refresh

# Public key from NeurQ (must match SaaS LICENSE_PRIVATE_KEY)
LICENSE_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# Online activation against NeurQ SaaS (optional if using offline .lic only)
LICENSE_SERVER_URL=https://api.qsasset.com/api/v1

ONPREM_ORG_NAME=Acme Corp
OWNER_EMAIL=neurq-support@acme.local
OWNER_PASSWORD=ChangeMe@123
TENANT_ADMIN_EMAIL=admin@acme.local
TENANT_ADMIN_PASSWORD=ChangeMe@123
