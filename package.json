{
  "name": "assetcommand",
  "version": "0.1.0",
  "private": true,
  "description": "Enterprise Asset Monitoring & Management Platform",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "db:migrate": "npm run db:migrate --workspace=apps/api",
    "db:seed": "npm run db:seed --workspace=apps/api",
    "db:studio": "npm run db:studio --workspace=apps/api"
  },
  "devDependencies": {
    "turbo": "^2.5.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "overrides": {
    "multer": "2.2.0",
    "ws": "8.21.1",
    "tmp": "0.2.7",
    "qs": "6.15.2",
    "js-yaml": "5.2.1",
    "adm-zip": "0.6.0",
    "form-data": "4.0.6",
    "engine.io": {
      ".": "6.6.9",
      "ws": "8.21.1"
    },
    "engine.io-client": {
      ".": "6.6.6",
      "ws": "8.21.1"
    },
    "socket.io-adapter": {
      ".": "2.5.8",
      "ws": "8.21.1"
    }
  },
  "packageManager": "npm@11.6.2"
}
