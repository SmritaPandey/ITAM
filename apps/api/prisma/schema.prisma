  @@map("automation_rules")
}

model AutomationExecution {
  id          String   @id @default(uuid()) @db.Uuid
  ruleId      String   @map("rule_id") @db.Uuid
  status      String   @default("SUCCESS") // SUCCESS, FAILED, SKIPPED
