// ─── Automation Engine ───────────────────────────────

enum RuleStatus {
  ACTIVE
  PAUSED
  DRAFT
}

model AutomationRule {
  id               String     @id @default(uuid()) @db.Uuid
  tenantId         String     @map("tenant_id") @db.Uuid
  name             String
  description      String?
  triggerModule    String     @map("trigger_module")
  triggerEvent     String     @map("trigger_event")
  condition        String?
  actionModule     String     @map("action_module")
  actionType       String     @map("action_type")
  actionConfig     Json       @default("{}") @map("action_config")
  status           RuleStatus @default(DRAFT)
  runCount         Int        @default(0) @map("run_count")
  lastRunAt        DateTime?  @map("last_run_at")
  cooldownMinutes  Int        @default(0) @map("cooldown_minutes")
  lastTriggeredAt  DateTime?  @map("last_triggered_at")
  chainedRuleId    String?    @map("chained_rule_id") @db.Uuid
  dedupKey         String?    @map("dedup_key")
  createdById      String?    @map("created_by_id") @db.Uuid
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")

