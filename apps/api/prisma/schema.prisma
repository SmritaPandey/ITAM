// ─── Discovery Engine ────────────────────────────────

enum ScanStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum ScanType {
  PING_SWEEP
  ARP_SCAN
  PORT_SCAN
  TCP_PORT_SCAN
  SNMP_DISCOVERY
  FULL_SCAN
}

model ScanJob {
  id          String     @id @default(uuid()) @db.Uuid
  tenantId    String     @map("tenant_id") @db.Uuid
  name        String?
  scanType    ScanType   @default(PING_SWEEP) @map("scan_type")
  subnet      String                             // e.g. "192.168.1.0/24"
  portRange   String?    @map("port_range")      // e.g. "22,80,443,3389"
  status      ScanStatus @default(PENDING)
  startedAt   DateTime?  @map("started_at")
  completedAt DateTime?  @map("completed_at")
  devicesFound Int       @default(0) @map("devices_found")
  newDevices   Int       @default(0) @map("new_devices")
  errorMessage String?   @map("error_message")
  triggeredById String?  @map("triggered_by_id") @db.Uuid
  createdAt   DateTime   @default(now()) @map("created_at")

  tenant      Tenant     @relation(fields: [tenantId], references: [id])
  triggeredBy User?      @relation("ScanTriggeredBy", fields: [triggeredById], references: [id])
  discoveries DiscoveredDevice[]

  @@index([tenantId])
  @@map("scan_jobs")
}

model DiscoveredDevice {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  scanJobId    String   @map("scan_job_id") @db.Uuid
  ipAddress    String   @map("ip_address")
  macAddress   String?  @map("mac_address")
  hostname     String?
  openPorts    String?  @map("open_ports")         // JSON array "[{port:22,service:'SSH'}]"
  osGuess      String?  @map("os_guess")
  osInfo       String?  @map("os_info")
  services     String?                              // JSON array of detected services
  manufacturer String?
  deviceType   String?  @map("device_type")        // Server, Workstation, Printer, etc.
  status       String   @default("PENDING_REVIEW") // PENDING_REVIEW, APPROVED, IGNORED, MERGED
  enrichmentData Json?  @map("enrichment_data")   // Raw WMI/SSH/SNMP collection results
  enrichmentStatus String @default("BASIC") @map("enrichment_status") // BASIC, ENRICHED, FAILED
  approvedAssetId String? @map("approved_asset_id") @db.Uuid
  riskScore    Int      @default(0) @map("risk_score")   // 0-100, higher = riskier
  firstSeenAt  DateTime @default(now()) @map("first_seen_at")
  lastSeenAt   DateTime @default(now()) @map("last_seen_at")
  seenCount    Int      @default(1) @map("seen_count")
  createdAt    DateTime @default(now()) @map("created_at")

  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  scanJob      ScanJob  @relation(fields: [scanJobId], references: [id], onDelete: Cascade)

  @@unique([tenantId, ipAddress])
  @@index([tenantId])
  @@index([scanJobId])
  @@map("discovered_devices")
}

// ─── License Management ──────────────────────────────

enum LicenseType {
  PER_SEAT
  PER_DEVICE
  SITE
  ENTERPRISE
  SUBSCRIPTION
  CONCURRENT
  OPEN_SOURCE
}

enum LicenseModel {
  PERPETUAL
  ANNUAL
  MONTHLY
  USAGE_BASED
  FREEMIUM
}

model License {
  id             String       @id @default(uuid()) @db.Uuid
  tenantId       String       @map("tenant_id") @db.Uuid
  softwareName   String       @map("software_name")
  softwareCatalogId String?   @map("software_catalog_id") @db.Uuid
  vendor         String?
  version        String?
  licenseKey     String?      @map("license_key")
  licenseType    LicenseType  @default(PER_SEAT) @map("license_type")
  licenseModel   LicenseModel @default(ANNUAL) @map("license_model")
  totalSeats     Int          @default(1) @map("total_seats")
  usedSeats      Int          @default(0) @map("used_seats")
  purchaseDate   DateTime?    @map("purchase_date")
  expiryDate     DateTime?    @map("expiry_date")
  renewalCost    Decimal?     @map("renewal_cost") @db.Decimal(12, 2)
  purchaseCost   Decimal?     @map("purchase_cost") @db.Decimal(12, 2)
  poNumber       String?      @map("po_number")
  notes          String?
  status         String       @default("ACTIVE") // ACTIVE, EXPIRED, REVOKED
  // Metering
  actualUsage      Int?        @map("actual_usage")       // actual installations found
  lastMeasuredAt   DateTime?   @map("last_measured_at")
  complianceStatus String?     @map("compliance_status")  // COMPLIANT, OVER_LICENSED, UNDER_LICENSED, UNKNOWN
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  tenant           Tenant           @relation(fields: [tenantId], references: [id])
  softwareCatalog  SoftwareCatalog? @relation(fields: [softwareCatalogId], references: [id])
  assignments      LicenseAssignment[]

  @@index([tenantId])
  @@index([tenantId, softwareCatalogId])
  @@map("licenses")
}

model LicenseAssignment {
  id          String   @id @default(uuid()) @db.Uuid
  licenseId   String   @map("license_id") @db.Uuid
  userId      String?  @map("user_id") @db.Uuid
  assetId     String?  @map("asset_id") @db.Uuid
  assignedAt  DateTime @default(now()) @map("assigned_at")
  revokedAt   DateTime? @map("revoked_at")

  license     License  @relation(fields: [licenseId], references: [id], onDelete: Cascade)
  user        User?    @relation(fields: [userId], references: [id])
  asset       Asset?   @relation(fields: [assetId], references: [id])

  @@index([licenseId])
  @@index([userId])
  @@index([assetId])
  @@map("license_assignments")
}

// ─── Notifications ───────────────────────────────────

model Notification {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  title       String
  message     String
  type        String   @default("INFO")    // INFO, WARNING, ALERT, SUCCESS
  module      String?                       // tickets, discovery, licenses, assets, etc.
  resourceId  String?  @map("resource_id")
  isRead      Boolean  @default(false) @map("is_read")
  createdAt   DateTime @default(now()) @map("created_at")

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
