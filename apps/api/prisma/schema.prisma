// ─── Patch Management ───────────────────────────────────────────────────────
model Patch {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  patchId         String   @map("patch_id")             // e.g. KB5034441
  title           String
  severity        String   @default("Medium")           // Critical, High, Medium, Low
  status          String   @default("Pending")           // Deployed, Pending, Scheduled, Failed
  category        String   @default("Security")
  affectedAssets  Int      @default(0) @map("affected_assets")
  deployedDate    DateTime? @map("deployed_date")
  notes           String?
  lastScanAt      DateTime? @map("last_scan_at")
  scanSource      String?   @map("scan_source")          // MANUAL, AGENT, SCHEDULED
  scanOutput      Json      @default("{}") @map("scan_output")
  // Scheduled deployment window
  scheduledAt     DateTime? @map("scheduled_at")        // When to deploy
  maintenanceEnd  DateTime? @map("maintenance_end")     // End of maintenance window
  recurring       String?                                // null, 'weekly', 'monthly'
  cronExpression  String?   @map("cron_expression")     // e.g. '0 2 * * 0' for Sunday 2AM
  autoApprove     Boolean   @default(false) @map("auto_approve")
  // Rollback support
  rollbackAvailable Boolean @default(false) @map("rollback_available")
  rollbackData      Json?   @map("rollback_data")        // Pre-patch state snapshot
  rolledBackAt      DateTime? @map("rolled_back_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  deployments     PatchDeployment[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("patches")
}

// ─── Patch Deployments (per-asset tracking) ─────────────────────────────────
model PatchDeployment {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  patchId     String    @map("patch_id") @db.Uuid
  assetId     String    @map("asset_id") @db.Uuid
  status      String    @default("PENDING")    // PENDING, DEPLOYING, DEPLOYED, FAILED
  output      String?   @db.Text
  deployedAt  DateTime? @map("deployed_at")
  preState    Json?     @map("pre_state")   // Pre-patch state for rollback
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  patch       Patch     @relation(fields: [patchId], references: [id], onDelete: Cascade)
  asset       Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([patchId, assetId])
  @@index([tenantId])
  @@map("patch_deployments")
}

// ─── Discovery Agents ───────────────────────────────────────────────────────
model Agent {
  id            String    @id @default(uuid()) @db.Uuid
  tenantId      String    @map("tenant_id") @db.Uuid
