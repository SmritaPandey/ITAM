generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// TENANT & AUTH
// ============================================================================

enum TenantStatus {
  ACTIVE
  SUSPENDED
  TRIAL
  CANCELLED
}

enum TenantPlan {
  STARTER
  PROFESSIONAL
  ENTERPRISE
  ON_PREMISE
}

model Tenant {
  id        String       @id @default(uuid()) @db.Uuid
  name      String
  slug      String       @unique
  domain    String?
  plan      TenantPlan   @default(STARTER)
  status    TenantStatus @default(ACTIVE)
  logoUrl   String?      @map("logo_url")
  settings  Json         @default("{}")
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  sites       Site[]
  departments Department[]
  users       User[]
  roles       Role[]
  assets      Asset[]
  assetTypes  AssetType[]
  tickets     Ticket[]
  auditLogs   AuditLog[]
  apiKeys     ApiKey[]
  scanJobs    ScanJob[]
  discoveredDevices DiscoveredDevice[]
  licenses    License[]
  notifications Notification[]
  automationRules AutomationRule[]
  monitoredDevices MonitoredDevice[]
  patches     Patch[]
  agents      Agent[]
  scanCredentials ScanCredential[]
  scheduledScans  ScheduledScan[]
  knowledgeArticles KnowledgeArticle[]
  slaPolicies     SlaPolicy[]
  scheduledReports ScheduledReport[]
  workOrders      WorkOrder[]
  scriptLibrary   ScriptLibrary[]
  networkConfigs  NetworkConfig[]
  patchDeployments PatchDeployment[]
  scanResults     ScanResult[]
  vendors         Vendor[]
  contracts       Contract[]
  purchaseOrders  PurchaseOrder[]
  assetCheckouts  AssetCheckout[]
  changeRequests  ChangeRequest[]
  problems        Problem[]
  assetAttestations AssetAttestation[]
  notificationChannels NotificationChannel[]
  endpointPolicies    EndpointPolicy[]
  endpointChanges     EndpointChange[]
  agentBaselines      AgentBaseline[]
  deviceMetricsHistory DeviceMetricsHistory[]
  subscription        Subscription?
  trips               Trip[]
  gpsTelemetries      GpsTelemetry[]
  serviceCatalogItems ServiceCatalogItem[]

  @@map("tenants")
}

model Site {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  name      String
  address   String?
  city      String?
  state     String?
  country   String?
  zipCode   String?  @map("zip_code")
  latitude  Float?
  longitude Float?
  timezone  String   @default("UTC")
  isHq      Boolean  @default(false) @map("is_hq")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  departments Department[]
  users       User[]
  assets      Asset[]

  @@index([tenantId])
  @@map("sites")
}

model Department {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  siteId     String?  @map("site_id") @db.Uuid
  name       String
  code       String?
  parentId   String?  @map("parent_id") @db.Uuid
  costCenter String?  @map("cost_center")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  tenant   Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  site     Site?       @relation(fields: [siteId], references: [id])
  parent   Department? @relation("DeptHierarchy", fields: [parentId], references: [id])
  children Department[] @relation("DeptHierarchy")
  users    User[]
  assets   Asset[]

  @@index([tenantId])
  @@map("departments")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  LOCKED
  PENDING
}

model User {
  id           String     @id @default(uuid()) @db.Uuid
  tenantId     String     @map("tenant_id") @db.Uuid
  email        String
  passwordHash String?    @map("password_hash")
  firstName    String     @map("first_name")
  lastName     String     @map("last_name")
  phone        String?
  avatarUrl    String?    @map("avatar_url")
  departmentId String?    @map("department_id") @db.Uuid
  siteId       String?    @map("site_id") @db.Uuid
  roleId       String     @map("role_id") @db.Uuid
  status       UserStatus @default(ACTIVE)
  isSuperAdmin Boolean    @default(false) @map("is_super_admin")
  emailVerified Boolean   @default(false) @map("email_verified")
  emailVerifyToken String? @map("email_verify_token")
  emailVerifyExpiry DateTime? @map("email_verify_expiry")
  passwordResetToken String? @map("password_reset_token")
  passwordResetExpiry DateTime? @map("password_reset_expiry")
  mfaEnabled   Boolean    @default(false) @map("mfa_enabled")
  mfaSecret    String?    @map("mfa_secret")
  // OAuth
  oauthProvider    String?   @map("oauth_provider")     // google, microsoft
  oauthProviderId  String?   @map("oauth_provider_id")  // provider-specific user ID
  lastLoginAt  DateTime?  @map("last_login_at")
  lastLoginIp  String?    @map("last_login_ip")
  preferences  Json       @default("{}") @map("preferences")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  deletedAt    DateTime?  @map("deleted_at")

  tenant        Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  department    Department? @relation(fields: [departmentId], references: [id])
  site          Site?       @relation(fields: [siteId], references: [id])
  role          Role        @relation(fields: [roleId], references: [id])
  assignedAssets Asset[]    @relation("AssetAssignee")
  managedAssets  Asset[]    @relation("AssetManager")
  createdAssets  Asset[]    @relation("AssetCreator")
  ticketsCreated  Ticket[]  @relation("TicketRequester")
  ticketsAssigned Ticket[]  @relation("TicketAssignee")
  auditLogs      AuditLog[]
  apiKeys        ApiKey[]
  refreshTokens  RefreshToken[]
  comments       TicketComment[] @relation("CommentAuthor")
  triggeredScans ScanJob[]       @relation("ScanTriggeredBy")
  notifications  Notification[]
  createdRules   AutomationRule[] @relation("RuleCreator")
  licenseAssignments LicenseAssignment[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([email])
  @@map("users")
}

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  name        String
  description String?
  isSystem    Boolean  @default(false) @map("is_system")
  permissions Json     @default("[]")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users  User[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("roles")
}

model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  revokedAt DateTime? @map("revoked_at")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model ApiKey {
  id        String    @id @default(uuid()) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  name      String
  keyHash   String    @unique @map("key_hash")
  keyPrefix String    @map("key_prefix")
  scopes    Json      @default("[]")
  expiresAt DateTime? @map("expires_at")
  lastUsedAt DateTime? @map("last_used_at")
  createdAt DateTime  @default(now()) @map("created_at")
  revokedAt DateTime? @map("revoked_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("api_keys")
}

// ============================================================================
// AUDIT LOG (Append-Only)
// ============================================================================

enum AuditSeverity {
  INFO
  WARNING
  CRITICAL
}

enum AuditOutcome {
  SUCCESS
  FAILURE
}

model AuditLog {
  id           String        @id @default(uuid()) @db.Uuid
  tenantId     String        @map("tenant_id") @db.Uuid
  timestamp    DateTime      @default(now())
  actorId      String?       @map("actor_id") @db.Uuid
  actorIp      String?       @map("actor_ip")
  actorAgent   String?       @map("actor_agent")
  action       String
  resourceType String        @map("resource_type")
  resourceId   String?       @map("resource_id")
  resourceName String?       @map("resource_name")
  before       Json?
  after        Json?
  metadata     Json?
  outcome      AuditOutcome  @default(SUCCESS)
  severity     AuditSeverity @default(INFO)
  module       String
  hash         String?
  prevHash     String?       @map("prev_hash")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  actor  User?  @relation(fields: [actorId], references: [id])

  @@index([tenantId, timestamp])
  @@index([tenantId, action])
  @@index([tenantId, resourceType, resourceId])
  @@map("audit_logs")
}

// ============================================================================
// ASSET MANAGEMENT (CMDB Core)
// ============================================================================

model AssetType {
  id               String   @id @default(uuid()) @db.Uuid
  tenantId         String   @map("tenant_id") @db.Uuid
  name             String
  parentId         String?  @map("parent_id") @db.Uuid
  icon             String?
  color            String?
  isItAsset        Boolean  @default(true) @map("is_it_asset")
  customFieldsSchema Json   @default("[]") @map("custom_fields_schema")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  tenant   Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent   AssetType? @relation("AssetTypeHierarchy", fields: [parentId], references: [id])
  children AssetType[] @relation("AssetTypeHierarchy")
  assets   Asset[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("asset_types")
}

enum AssetStatus {
  DISCOVERED
  ACTIVE
  IN_MAINTENANCE
  IN_STORAGE
  RESERVED
  RETIRED
  DISPOSED
  LOST
  PENDING_REVIEW
}

enum DiscoverySource {
  AGENT
  SNMP
  WMI
  SSH
  NETWORK_SCAN
  CLOUD_AWS
  CLOUD_AZURE
  CLOUD_GCP
  ACTIVE_DIRECTORY
  MANUAL
  CSV_IMPORT
  API
  ONVIF
}

model Asset {
  id              String          @id @default(uuid()) @db.Uuid
  tenantId        String          @map("tenant_id") @db.Uuid
  assetTypeId     String          @map("asset_type_id") @db.Uuid
  // Identity
  assetTag        String?         @map("asset_tag")
  name            String
  serialNumber    String?         @map("serial_number")
  barcode         String?
  // Classification
  category        String?
  subCategory     String?         @map("sub_category")
  manufacturer    String?
  model           String?
  // Location
  siteId          String?         @map("site_id") @db.Uuid
  departmentId    String?         @map("department_id") @db.Uuid
  floor           String?
  room            String?
  rack            String?
  position        String?
  // Ownership
  assignedToId    String?         @map("assigned_to_id") @db.Uuid
  managedById     String?         @map("managed_by_id") @db.Uuid
  // Lifecycle
  status          AssetStatus     @default(DISCOVERED)
  procurementDate DateTime?       @map("procurement_date")
  deploymentDate  DateTime?       @map("deployment_date")
  warrantyExpiry  DateTime?       @map("warranty_expiry")
  eolDate         DateTime?       @map("eol_date")
  disposalDate    DateTime?       @map("disposal_date")
  // Financial
  purchasePrice   Decimal?        @map("purchase_price") @db.Decimal(12, 2)
  currentValue    Decimal?        @map("current_value") @db.Decimal(12, 2)
  salvageValue    Decimal?        @map("salvage_value") @db.Decimal(12, 2)
  usefulLifeMonths Int?           @map("useful_life_months")
  depreciationMethod String?      @map("depreciation_method") // STRAIGHT_LINE, DECLINING_BALANCE
  poNumber        String?         @map("po_number")
  invoiceNumber   String?         @map("invoice_number")
  // Lease
  leaseStartDate  DateTime?       @map("lease_start_date")
  leaseEndDate    DateTime?       @map("lease_end_date")
  leaseVendor     String?         @map("lease_vendor")
  monthlyLeaseCost Decimal?       @map("monthly_lease_cost") @db.Decimal(12, 2)
  leaseContractId String?         @map("lease_contract_id") @db.Uuid
  vendorId        String?         @map("vendor_id") @db.Uuid
  // Network (IT assets)
  ipAddress       String?         @map("ip_address")
  macAddress      String?         @map("mac_address")
  hostname        String?
  fqdn            String?
  // GPS (Fleet assets) - stored as floats; PostGIS queries via raw SQL
  latitude        Float?
  longitude       Float?
  // Flexible attributes
  customFields    Json            @default("{}") @map("custom_fields")
  tags            String[]        @default([])
  // Discovery
  discoverySource DiscoverySource? @map("discovery_source")
  lastScannedAt   DateTime?       @map("last_scanned_at")
  agentId         String?         @map("agent_id")
  // Meta
  parentAssetId   String?         @map("parent_asset_id") @db.Uuid
  notes           String?
  createdById     String?         @map("created_by_id") @db.Uuid
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  deletedAt       DateTime?       @map("deleted_at")

  tenant       Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assetType    AssetType   @relation(fields: [assetTypeId], references: [id])
  site         Site?       @relation(fields: [siteId], references: [id])
  department   Department? @relation(fields: [departmentId], references: [id])
  assignedTo   User?       @relation("AssetAssignee", fields: [assignedToId], references: [id])
  managedBy    User?       @relation("AssetManager", fields: [managedById], references: [id])
  createdBy    User?       @relation("AssetCreator", fields: [createdById], references: [id])
  parentAsset  Asset?      @relation("AssetHierarchy", fields: [parentAssetId], references: [id])
  childAssets  Asset[]     @relation("AssetHierarchy")

  hardwareDetails   HardwareDetail?
  osDetails         OsDetail?
  securityPosture   SecurityPosture?
  softwareInstalls  SoftwareInstallation[]
  assetHistory      AssetHistory[]
  tickets           TicketAsset[]
  workOrders        WorkOrder[]
  patchDeployments  PatchDeployment[]
  checkouts         AssetCheckout[]
  attestations      AssetAttestation[]
  licenseAssignments LicenseAssignment[]
  sourceRelations   AssetRelationship[] @relation("RelSource")
  targetRelations   AssetRelationship[] @relation("RelTarget")
  trips             Trip[]
  gpsTelemetries    GpsTelemetry[]

  @@unique([tenantId, assetTag])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, assetTypeId])
  @@index([tenantId, ipAddress])
  @@index([tenantId, macAddress])
  @@index([tenantId, serialNumber])
  @@index([tenantId, hostname])
  @@map("assets")
}

enum RelationshipType {
  DEPENDS_ON
  COMPONENT_OF
  CONNECTED_TO
  RUNS_ON
  USED_BY
  BACKUP_OF
}

model AssetRelationship {
  id               String           @id @default(uuid()) @db.Uuid
  tenantId         String           @map("tenant_id") @db.Uuid
  sourceAssetId    String           @map("source_asset_id") @db.Uuid
  targetAssetId    String           @map("target_asset_id") @db.Uuid
  relationshipType RelationshipType @map("relationship_type")
  properties       Json             @default("{}")
  createdAt        DateTime         @default(now()) @map("created_at")

  sourceAsset Asset @relation("RelSource", fields: [sourceAssetId], references: [id], onDelete: Cascade)
  targetAsset Asset @relation("RelTarget", fields: [targetAssetId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("asset_relationships")
}

model AssetHistory {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  assetId     String   @map("asset_id") @db.Uuid
  eventType   String   @map("event_type")
  description String?
  performedBy String?  @map("performed_by")
  details     Json     @default("{}")
  timestamp   DateTime @default(now())

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([tenantId, assetId])
  @@map("asset_history")
}

// ============================================================================
// IT ASSET DETAIL TABLES
// ============================================================================

model HardwareDetail {
  id             String  @id @default(uuid()) @db.Uuid
  assetId        String  @unique @map("asset_id") @db.Uuid
  cpuModel       String? @map("cpu_model")
  cpuCores       Int?    @map("cpu_cores")
  cpuSpeedGhz    Float?  @map("cpu_speed_ghz")
  ramTotalGb     Float?  @map("ram_total_gb")
  ramType        String? @map("ram_type")
  diskTotalGb    Float?  @map("disk_total_gb")
  diskType       String? @map("disk_type")
  diskHealth     String? @map("disk_health")
  gpuModel       String? @map("gpu_model")
  gpuVramGb      Float?  @map("gpu_vram_gb")
  biosVersion    String? @map("bios_version")
  biosVendor     String? @map("bios_vendor")
  tpmVersion     String? @map("tpm_version")
  tpmEnabled     Boolean? @map("tpm_enabled")
  formFactor     String? @map("form_factor")

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@map("hardware_details")
}

model OsDetail {
  id             String    @id @default(uuid()) @db.Uuid
  assetId        String    @unique @map("asset_id") @db.Uuid
  osName         String?   @map("os_name")
  osVersion      String?   @map("os_version")
  osBuild        String?   @map("os_build")
  osArchitecture String?   @map("os_architecture")
  installDate    DateTime? @map("install_date")
  lastBoot       DateTime? @map("last_boot")
  uptimeDays     Int?      @map("uptime_days")

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@map("os_details")
}

model SecurityPosture {
  id                   String    @id @default(uuid()) @db.Uuid
  assetId              String    @unique @map("asset_id") @db.Uuid
  avInstalled          Boolean?  @map("av_installed")
  avName               String?   @map("av_name")
  avVersion            String?   @map("av_version")
  avDefinitionsDate    DateTime? @map("av_definitions_date")
  avRealtimeProtection Boolean?  @map("av_realtime_protection")
  firewallEnabled      Boolean?  @map("firewall_enabled")
  encryptionEnabled    Boolean?  @map("encryption_enabled")
  encryptionType       String?   @map("encryption_type")
  encryptionPercent    Int?      @map("encryption_percent")
  complianceScore      Int?      @map("compliance_score")
  lastAssessedAt       DateTime? @map("last_assessed_at")

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@map("security_postures")
}

model SoftwareCatalog {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  name          String
  publisher     String?
  category      String?
  isBlacklisted Boolean  @default(false) @map("is_blacklisted")
  isAuthorized  Boolean  @default(true) @map("is_authorized")
  authorizationStatus String @default("NEEDS_REVIEW") @map("authorization_status")
  latestVersion String?  @map("latest_version")
  // Lifecycle tracking (Qualys CSAM-inspired)
  eolDate       DateTime? @map("eol_date")
  eosDate       DateTime? @map("eos_date")
  lifecycleStatus String? @map("lifecycle_status")
  riskScore     Int?      @map("risk_score")
  description   String?
  website       String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")

  installations SoftwareInstallation[]
  licenses      License[]

  @@unique([tenantId, name, publisher])
  @@index([tenantId])
  @@index([tenantId, authorizationStatus])
  @@map("software_catalog")
}

model SoftwareInstallation {
  id           String    @id @default(uuid()) @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  assetId      String    @map("asset_id") @db.Uuid
  softwareId   String    @map("software_id") @db.Uuid
  version      String?
  installDate  DateTime? @map("install_date")
  installPath  String?   @map("install_path")
  lastUsedAt   DateTime? @map("last_used_at")

  asset    Asset           @relation(fields: [assetId], references: [id], onDelete: Cascade)
  software SoftwareCatalog @relation(fields: [softwareId], references: [id])

  @@index([tenantId, assetId])
  @@map("software_installations")
}

// ============================================================================
// ITSM / TICKETING
// ============================================================================

enum TicketType {
  INCIDENT
  PROBLEM
  CHANGE
  SERVICE_REQUEST
  MAINTENANCE
}

enum TicketStatus {
  NEW
  OPEN
  IN_PROGRESS
  PENDING
  ON_HOLD
  RESOLVED
  CLOSED
  CANCELLED
}

enum TicketPriority {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

model Ticket {
  id              String         @id @default(uuid()) @db.Uuid
  tenantId        String         @map("tenant_id") @db.Uuid
  ticketNumber    String         @map("ticket_number")
  type            TicketType     @default(INCIDENT)
  category        String?
  subCategory     String?        @map("sub_category")
  subject         String
  description     String?
  priority        TicketPriority @default(MEDIUM)
  status          TicketStatus   @default(NEW)
  requesterId     String         @map("requester_id") @db.Uuid
  assignedToId    String?        @map("assigned_to_id") @db.Uuid
  assignedGroup   String?        @map("assigned_group")
  responseDueAt   DateTime?      @map("response_due_at")
  resolutionDueAt DateTime?      @map("resolution_due_at")
  respondedAt     DateTime?      @map("responded_at")
  resolvedAt      DateTime?      @map("resolved_at")
  closedAt        DateTime?      @map("closed_at")
  satisfactionScore Int?         @map("satisfaction_score")
  parentTicketId  String?        @map("parent_ticket_id") @db.Uuid
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  requester    User          @relation("TicketRequester", fields: [requesterId], references: [id])
  assignedTo   User?         @relation("TicketAssignee", fields: [assignedToId], references: [id])
  parentTicket Ticket?       @relation("TicketHierarchy", fields: [parentTicketId], references: [id])
  childTickets Ticket[]      @relation("TicketHierarchy")
  comments     TicketComment[]
  assets       TicketAsset[]
  workOrders   WorkOrder[]

  @@unique([tenantId, ticketNumber])
  @@index([tenantId, status])
  @@index([tenantId, assignedToId])
  @@index([tenantId, requesterId])
  @@map("tickets")
}

// ─── Work Orders ──────────────────────────────────────
model WorkOrder {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  workOrderNumber String   @map("work_order_number")
  ticketId        String?  @map("ticket_id") @db.Uuid
  assetId         String?  @map("asset_id") @db.Uuid
  title           String
  description     String?
  type            String   @default("MAINTENANCE") // MAINTENANCE, REPAIR, INSTALLATION, INSPECTION
  priority        String   @default("MEDIUM")
  status          String   @default("CREATED")     // CREATED, ASSIGNED, IN_PROGRESS, COMPLETED, VERIFIED, CANCELLED
  assignedToId    String?  @map("assigned_to_id") @db.Uuid
  scheduledStart  DateTime? @map("scheduled_start")
  scheduledEnd    DateTime? @map("scheduled_end")
  actualStart     DateTime? @map("actual_start")
  actualEnd       DateTime? @map("actual_end")
  laborHours      Float?   @map("labor_hours")
  materialCost    Float?   @map("material_cost")
  notes           String?
  completedById   String?  @map("completed_by_id") @db.Uuid
  verifiedById    String?  @map("verified_by_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
