# Copy to .env.onprem.ha and use with docker-compose.ha.yml.
HTTP_PORT=80
DB_PASSWORD=replace-with-a-strong-database-password
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_REFRESH_SECRET=replace-with-another-32-random-characters
VAULT_ENCRYPTION_KEY=replace-with-at-least-32-random-characters

OWNER_EMAIL=owner@localhost
OWNER_PASSWORD=replace-with-a-strong-owner-password
TENANT_ADMIN_EMAIL=admin@localhost
TENANT_ADMIN_PASSWORD=replace-with-a-strong-admin-password
CORS_ORIGIN=http://localhost

# Public verification keys only. Keep signing private keys off the appliance.
LICENSE_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
PLATFORM_UPDATE_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
PLATFORM_UPDATE_MANIFEST_PATH=/app/.artifacts/platform-release.json
# Needed only when manifest image values are bare sha256 digests rather than full image@digest refs.
PLATFORM_API_IMAGE_REPOSITORY=registry.example.com/qs-assets/api
PLATFORM_WEB_IMAGE_REPOSITORY=registry.example.com/qs-assets/web

# Dedicated collector replica UDP listeners.
ENABLE_SNMP_TRAPS=true
ENABLE_SYSLOG=true
ENABLE_NETFLOW=true
SNMP_TRAP_PORT=1162
SYSLOG_UDP_PORT=5514
NETFLOW_UDP_PORT=2055
