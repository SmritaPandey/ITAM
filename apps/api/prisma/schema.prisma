model Contract {
  id              String    @id @default(uuid()) @db.Uuid
  tenantId        String    @map("tenant_id") @db.Uuid
  vendorId        String    @map("vendor_id") @db.Uuid
  contractNumber  String?   @map("contract_number")
  title           String
  type            String    // WARRANTY, MAINTENANCE, LEASE, LICENSE, SUPPORT, AMC
  startDate       DateTime  @map("start_date")
  endDate         DateTime  @map("end_date")
  value           Decimal?  @db.Decimal(12, 2)
  currency        String    @default("INR")
  autoRenew       Boolean   @default(false) @map("auto_renew")
  renewalAlertDays Int      @default(30) @map("renewal_alert_days")
  status          String    @default("ACTIVE") // ACTIVE, EXPIRED, PENDING_RENEWAL, CANCELLED
  attachments     Json      @default("[]")  // file paths
  terms           String?   @db.Text
  notes           String?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  tenant          Tenant    @relation(fields: [tenantId], references: [id])
  vendor          Vendor    @relation(fields: [vendorId], references: [id])

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("contracts")
}

model PurchaseOrder {
  id              String    @id @default(uuid()) @db.Uuid
  tenantId        String    @map("tenant_id") @db.Uuid
  vendorId        String    @map("vendor_id") @db.Uuid
  poNumber        String    @map("po_number")
  status          String    @default("DRAFT") // DRAFT, SUBMITTED, APPROVED, PARTIALLY_RECEIVED, RECEIVED, CANCELLED
  requestedById   String    @map("requested_by_id") @db.Uuid
  approvedById    String?   @map("approved_by_id") @db.Uuid
  totalAmount     Decimal   @default(0) @map("total_amount") @db.Decimal(12, 2)
  currency        String    @default("INR")
  shippingAddress String?   @map("shipping_address")
  expectedDelivery DateTime? @map("expected_delivery")
  receivedDate    DateTime? @map("received_date")
  notes           String?
  approvedAt      DateTime? @map("approved_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  tenant          Tenant    @relation(fields: [tenantId], references: [id])
  vendor          Vendor    @relation(fields: [vendorId], references: [id])
  items           PurchaseOrderItem[]

  @@unique([tenantId, poNumber])
  @@index([tenantId])
  @@index([tenantId, status])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String    @id @default(uuid()) @db.Uuid
  poId            String    @map("po_id") @db.Uuid
  description     String
  assetTypeId     String?   @map("asset_type_id") @db.Uuid
  quantity        Int       @default(1)
  unitPrice       Decimal   @default(0) @map("unit_price") @db.Decimal(12, 2)
  totalPrice      Decimal   @default(0) @map("total_price") @db.Decimal(12, 2)
  receivedQty     Int       @default(0) @map("received_qty")

  purchaseOrder   PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)

  @@index([poId])
  @@map("purchase_order_items")
}

// ─── Asset Check-in / Check-out ────────────────────────────────────────────
model AssetCheckout {
  id              String    @id @default(uuid()) @db.Uuid
  tenantId        String    @map("tenant_id") @db.Uuid
  assetId         String    @map("asset_id") @db.Uuid
  userId          String    @map("user_id") @db.Uuid       // checked out TO
  checkedOutById  String    @map("checked_out_by_id") @db.Uuid // checked out BY
  checkedOutAt    DateTime  @default(now()) @map("checked_out_at")
  expectedReturn  DateTime? @map("expected_return")
  actualReturn    DateTime? @map("actual_return")
  condition       String    @default("GOOD") // GOOD, FAIR, DAMAGED, LOST
  notes           String?
  status          String    @default("CHECKED_OUT") // CHECKED_OUT, RETURNED, OVERDUE

  tenant          Tenant    @relation(fields: [tenantId], references: [id])
  asset           Asset     @relation(fields: [assetId], references: [id])

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("asset_checkouts")
}

// ─── Change Management (ITIL) ──────────────────────────────────────────────
model ChangeRequest {
  id              String    @id @default(uuid()) @db.Uuid
  tenantId        String    @map("tenant_id") @db.Uuid
  changeNumber    String    @map("change_number")
  title           String
  description     String?   @db.Text
  type            String    @default("NORMAL") // STANDARD, NORMAL, EMERGENCY
  category        String?   // INFRASTRUCTURE, SOFTWARE, NETWORK, SECURITY, DATABASE
  priority        String    @default("MEDIUM") // LOW, MEDIUM, HIGH, CRITICAL
  risk            String    @default("MEDIUM") // LOW, MEDIUM, HIGH, CRITICAL
  status          String    @default("DRAFT") // DRAFT, SUBMITTED, APPROVED, REJECTED, IN_PROGRESS, COMPLETED, FAILED, ROLLED_BACK, CANCELLED
  requestedById   String    @map("requested_by_id") @db.Uuid
  approvedById    String?   @map("approved_by_id") @db.Uuid
  implementedById String?   @map("implemented_by_id") @db.Uuid
  scheduledStart  DateTime? @map("scheduled_start")
  scheduledEnd    DateTime? @map("scheduled_end")
  actualStart     DateTime? @map("actual_start")
  actualEnd       DateTime? @map("actual_end")
  impactAnalysis  String?   @map("impact_analysis") @db.Text
  rollbackPlan    String?   @map("rollback_plan") @db.Text
  testPlan        String?   @map("test_plan") @db.Text
  affectedAssets  Json      @default("[]") @map("affected_assets")
  affectedServices Json     @default("[]") @map("affected_services")
  relatedTickets  Json      @default("[]") @map("related_tickets")
  closureNotes    String?   @map("closure_notes") @db.Text
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  tenant          Tenant    @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, changeNumber])
  @@index([tenantId, status])
  @@map("change_requests")
}

// ─── Problem Management (ITIL) ─────────────────────────────────────────────
model Problem {
  id              String    @id @default(uuid()) @db.Uuid
  tenantId        String    @map("tenant_id") @db.Uuid
  problemNumber   String    @map("problem_number")
  title           String
  description     String?   @db.Text
  priority        String    @default("MEDIUM") // LOW, MEDIUM, HIGH, CRITICAL
  status          String    @default("OPEN") // OPEN, ROOT_CAUSE_IDENTIFIED, KNOWN_ERROR, RESOLVED, CLOSED
  category        String?
  rootCause       String?   @map("root_cause") @db.Text
  workaround      String?   @db.Text
  resolution      String?   @db.Text
  affectedAssets  Json      @default("[]") @map("affected_assets")
  relatedTickets  Json      @default("[]") @map("related_tickets")
  relatedChanges  Json      @default("[]") @map("related_changes")
  assignedToId    String?   @map("assigned_to_id") @db.Uuid
  identifiedAt    DateTime? @map("identified_at")
  resolvedAt      DateTime? @map("resolved_at")
  isKnownError    Boolean   @default(false) @map("is_known_error")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  tenant          Tenant    @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, problemNumber])
  @@index([tenantId, status])
  @@index([tenantId, isKnownError])
  @@map("problems")
}

// ─── Asset Attestation ─────────────────────────────────────────────────────
model AssetAttestation {
  id              String    @id @default(uuid()) @db.Uuid
  tenantId        String    @map("tenant_id") @db.Uuid
  assetId         String    @map("asset_id") @db.Uuid
  userId          String    @map("user_id") @db.Uuid
  campaignName    String?   @map("campaign_name")
  requestedAt     DateTime  @default(now()) @map("requested_at")
  respondedAt     DateTime? @map("responded_at")
  response        String?   // CONFIRMED, LOST, TRANSFERRED, NO_RESPONSE
  notes           String?

  tenant          Tenant    @relation(fields: [tenantId], references: [id])
  asset           Asset     @relation(fields: [assetId], references: [id])

  @@index([tenantId])
  @@index([tenantId, response])
  @@map("asset_attestations")
}

// ─── Notification Channels ─────────────────────────────────────────────────
model NotificationChannel {
  id              String    @id @default(uuid()) @db.Uuid
  tenantId        String    @map("tenant_id") @db.Uuid
  name            String
  type            String    // EMAIL, SLACK, TEAMS, WEBHOOK
  config          Json      @default("{}") // { webhookUrl, channel, smtpHost, etc. }
  isActive        Boolean   @default(true) @map("is_active")
  events          Json      @default("[]") // which events trigger this channel
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  tenant          Tenant    @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("notification_channels")
}

// ============================================================================
// ENDPOINT COMPLIANCE & CHANGE DETECTION
// ============================================================================

model EndpointPolicy {
  id              String    @id @default(uuid()) @db.Uuid
  tenantId        String    @map("tenant_id") @db.Uuid
  name            String
  description     String?
  category        String    // HARDWARE_CHANGE, SOFTWARE_INSTALL, SOFTWARE_REMOVE, USB_DEVICE, NETWORK_CHANGE, PROCESS_BLOCKED, RAM_CHANGE, DISK_CHANGE
  severity        String    @default("WARNING") // INFO, WARNING, CRITICAL
  action          String    @default("ALERT_ONLY") // ALERT_ONLY, REQUIRE_APPROVAL, AUTO_BLOCK
  matchPattern    Json      @default("{}") @map("match_pattern") // e.g. {"maxRamGb":16}, {"blockedSoftware":["BitTorrent"]}
  scope           Json      @default("{}") // {"platforms":["windows"],"hostnames":["HR-*"],"all":true}
  isActive        Boolean   @default(true) @map("is_active")
  isSystem        Boolean   @default(false) @map("is_system") // pre-built templates
  createdById     String?   @map("created_by_id") @db.Uuid
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  changes         EndpointChange[]

  @@index([tenantId])
  @@index([tenantId, category])
  @@map("endpoint_policies")
}

model EndpointChange {
  id              String    @id @default(uuid()) @db.Uuid
  tenantId        String    @map("tenant_id") @db.Uuid
  agentId         String    @map("agent_id") @db.Uuid
  policyId        String?   @map("policy_id") @db.Uuid
  category        String    // HARDWARE_CHANGE, SOFTWARE_INSTALL, SOFTWARE_REMOVE, USB_DEVICE, NETWORK_CHANGE, PROCESS_BLOCKED, RAM_CHANGE, DISK_CHANGE
  changeType      String    @map("change_type") // ADDED, REMOVED, MODIFIED
  severity        String    @default("INFO") // INFO, WARNING, CRITICAL
  summary         String    // Human-readable: "RAM changed from 8GB to 16GB"
  previousValue   Json?     @map("previous_value") // snapshot of the previous state
  newValue        Json?     @map("new_value") // snapshot of the new state
  status          String    @default("PENDING_REVIEW") // PENDING_REVIEW, APPROVED, REJECTED, AUTO_ALLOWED, VIOLATION
  reviewedById    String?   @map("reviewed_by_id") @db.Uuid
  reviewedAt      DateTime? @map("reviewed_at")
  reviewNote      String?   @map("review_note")
  hostname        String?   // Denormalized for fast filtering
  ipAddress       String?   @map("ip_address")
  platform        String?
  createdAt       DateTime  @default(now()) @map("created_at")

  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  agent           Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  policy          EndpointPolicy? @relation(fields: [policyId], references: [id])

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, agentId])
  @@index([tenantId, severity])
  @@map("endpoint_changes")
}

model AgentBaseline {
  id              String    @id @default(uuid()) @db.Uuid
  tenantId        String    @map("tenant_id") @db.Uuid
  agentId         String    @unique @map("agent_id") @db.Uuid
  snapshot        Json      @default("{}")
  snapshotAt      DateTime  @default(now()) @map("snapshot_at")

  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  agent           Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("agent_baselines")
}

// ─── Device Metrics History (SNMP Time-Series) ─────────────────────────────
model DeviceMetricsHistory {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  deviceId    String   @map("device_id") @db.Uuid
  metrics     Json     @default("{}")  // { cpu, ram, ifInOctets, ifOutOctets, latency, uptime }
  collectedAt DateTime @default(now()) @map("collected_at")

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  device      MonitoredDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId, collectedAt])
  @@index([tenantId])
  @@map("device_metrics_history")
}

// ============================================================================
// PLATFORM ADMIN — SUPPORT, SUBSCRIPTIONS & PAYMENTS
// ============================================================================

model ContactSubmission {
  id        String    @id @default(uuid()) @db.Uuid
  name      String
  email     String
  subject   String
  message   String
  status    String    @default("NEW")       // NEW, READ, REPLIED, ARCHIVED
  reply     String?
  repliedAt DateTime? @map("replied_at")
  ipAddress String?   @map("ip_address")
  userAgent String?   @map("user_agent")
  tenantId  String?   @map("tenant_id") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@index([status])
  @@index([email])
  @@map("contact_submissions")
}

model Subscription {
  id              String     @id @default(uuid()) @db.Uuid
  tenantId        String     @unique @map("tenant_id") @db.Uuid
  plan            TenantPlan
  status          String     @default("ACTIVE")   // ACTIVE, PAST_DUE, CANCELLED, TRIAL
  startDate       DateTime   @default(now()) @map("start_date")
  endDate         DateTime?  @map("end_date")
  trialEndsAt     DateTime?  @map("trial_ends_at")
  mrr             Decimal?   @db.Decimal(10, 2)
  billingCycle    String?    @default("MONTHLY") @map("billing_cycle")  // MONTHLY, QUARTERLY, ANNUAL, CUSTOM
  discountPercent Decimal?   @default(0) @db.Decimal(5, 2) @map("discount_percent")
  discountNote    String?    @map("discount_note")
  customPrice     Decimal?   @db.Decimal(10, 2) @map("custom_price")
  notes           String?
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  tenant      Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  payments    Payment[]

  @@map("subscriptions")
}

model Payment {
  id             String       @id @default(uuid()) @db.Uuid
  subscriptionId String       @map("subscription_id") @db.Uuid
  amount         Decimal      @db.Decimal(10, 2)
  currency       String       @default("INR")
  status         String       @default("COMPLETED")  // COMPLETED, PENDING, FAILED, REFUNDED
  method         String?                               // UPI, BANK_TRANSFER, RAZORPAY, MANUAL
  referenceId    String?      @map("reference_id")
  invoiceNumber  String?      @map("invoice_number")
  notes          String?
  paidAt         DateTime     @default(now()) @map("paid_at")
  createdAt      DateTime     @default(now()) @map("created_at")

  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
  @@map("payments")
}

model Trip {
  id            String    @id @default(uuid()) @db.Uuid
  tenantId      String    @map("tenant_id") @db.Uuid
  assetId       String    @map("asset_id") @db.Uuid
  startTime     DateTime  @map("start_time")
  endTime       DateTime? @map("end_time")
  distanceKm    Float     @map("distance_km")
  maxSpeed      Float     @map("max_speed")
  avgSpeed      Float     @map("avg_speed")
  startLocation String?   @map("start_location")
  endLocation   String?   @map("end_location")
  routeCoords   Json?     @map("route_coords") // Array of {lat, lng, speed, timestamp}
  createdAt     DateTime  @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  asset  Asset  @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([tenantId, assetId])
  @@map("trips")
}

model GpsTelemetry {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  assetId     String   @map("asset_id") @db.Uuid
  latitude    Float
  longitude   Float
  speed       Float
  fuelLevel   Float?   @map("fuel_level")
  collectedAt DateTime @default(now()) @map("collected_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  asset  Asset  @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([tenantId, assetId])
  @@map("gps_telemetries")
}

// ============================================================================
// USER TELEMETRY & COOKIE TRACKING (Platform Analytics)
// ============================================================================
model UserTelemetry {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String?  @map("tenant_id") @db.Uuid
  userId       String?  @map("user_id") @db.Uuid
  email        String?
  ipAddress    String?  @map("ip_address")
  userAgent    String?  @map("user_agent")
  path         String
  referrer     String?
  country      String?
  city         String?
  region       String?
  latitude     Float?
  longitude    Float?
  cookies      Json     @default("{}")
  sessionData  Json     @default("{}")
  trackedAt    DateTime @default(now()) @map("tracked_at")

  @@index([trackedAt])
  @@index([tenantId])
  @@map("user_telemetry")
}

model SystemConfig {
  key       String   @id
  value     Json
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_configs")
}

// ─── Service Catalog ────────────────────────────────────────────────────────
model ServiceCatalogItem {
  id               String   @id @default(uuid()) @db.Uuid
  tenantId         String   @map("tenant_id") @db.Uuid
  name             String
  category         String   @default("General")
  description      String?  @db.Text
  sla              String?  // e.g. "5 business days"
  approvalRequired Boolean  @default(false) @map("approval_required")
  icon             String   @default("circle")
  isActive         Boolean  @default(true) @map("is_active")
  sortOrder        Int      @default(0) @map("sort_order")
  formFields       Json     @default("[]") @map("form_fields") // Custom form fields for requests
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, category])
  @@map("service_catalog_items")
}

