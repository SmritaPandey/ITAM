  @@index([ruleId])
  @@map("automation_executions")
}

// ─── Monitoring: Cameras, NMS Devices, VDI VMs ──────────────────────────────
enum MonitoredDeviceType {
  CAMERA
  NETWORK_DEVICE
  VIRTUAL_MACHINE
}

model MonitoredDevice {
  id          String              @id @default(uuid()) @db.Uuid
  tenantId    String              @map("tenant_id") @db.Uuid
  type        MonitoredDeviceType
