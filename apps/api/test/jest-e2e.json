{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "moduleNameMapper": {
    "^uuid$": "<rootDir>/uuid-jest-shim.ts",
    "^meilisearch$": "<rootDir>/meilisearch-jest-shim.ts"
  },
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  }
}
