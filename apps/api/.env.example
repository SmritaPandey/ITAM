# =============================================================================
# QS Assets API — environment template
# Copy to .env for local Docker (see repo docker-compose.yml) or set in Railway.
# =============================================================================

# Database (local Docker PostGIS maps host 5434 → container 5432)
# DATABASE_URL="postgresql://assetcommand:assetcommand_dev@localhost:5434/assetcommand?schema=public"
DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public"

# Redis (local Docker maps host 6380 → container 6379)
REDIS_URL="redis://localhost:6380"

# Credential / secrets vault (32+ byte hex or base64). Required in production.
VAULT_ENCRYPTION_KEY=""

# JWT Secrets (generate strong random strings)
JWT_SECRET="change-me-in-production"
JWT_EXPIRATION="4h"
JWT_REFRESH_EXPIRATION="7d"

# Server
PORT=4100
NODE_ENV=development

# Application URL (used for OAuth callbacks)
APP_URL="http://localhost:3100"

# CORS - comma-separated allowed origins
CORS_ORIGIN="http://localhost:3100,http://localhost:3000"

# -----------------------------------------------------------------------------
# OAuth / SSO
# -----------------------------------------------------------------------------
# OAuth — Google (optional, leave empty to disable)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# OAuth — Microsoft / Azure AD (optional, leave empty to disable)
MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""

# OAuth callback URL (override if using custom domain)
OAUTH_CALLBACK_URL=""

# SAML 2.0 (optional)
SSO_SAML_ENTRY_POINT=""
SSO_SAML_ISSUER=""
SSO_SAML_CERT=""

# OIDC (optional)
OIDC_ISSUER=""
OIDC_CLIENT_ID=""
OIDC_CLIENT_SECRET=""

# -----------------------------------------------------------------------------
# Vulnerability / NVD
# -----------------------------------------------------------------------------
# Request a key at https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=""

# -----------------------------------------------------------------------------
# Payments (optional)
# -----------------------------------------------------------------------------
# Stripe (preferred when both Stripe and Razorpay are configured)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Razorpay / PayG
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""

# -----------------------------------------------------------------------------
# IoT / MQTT (optional — broker configs can also be stored per-tenant in DB)
# -----------------------------------------------------------------------------
MQTT_BROKER_URL=""
MQTT_USERNAME=""
MQTT_PASSWORD=""

# OT protocol probes (off by default — honest empty results when disabled)
MODBUS_PROBE_ENABLED=false
BACNET_PROBE_ENABLED=false

# -----------------------------------------------------------------------------
# NMS ingest (UDP collectors — off by default)
# -----------------------------------------------------------------------------
ENABLE_SYSLOG=false
SYSLOG_UDP_PORT=5514
ENABLE_NETFLOW=false
NETFLOW_UDP_PORT=2055
# SNMP traps (existing): ENABLE_SNMP_TRAPS=true / SNMP_TRAP_PORT=1162

# -----------------------------------------------------------------------------
# Search (Meilisearch — docker-compose service)
# -----------------------------------------------------------------------------
MEILI_HOST="http://localhost:7700"
MEILI_MASTER_KEY="assetcommand_dev_key"

# -----------------------------------------------------------------------------
# AI Engine (Gemma via vLLM or Ollama)
# -----------------------------------------------------------------------------
AI_ENABLED=false
AI_FEATURE_ENABLED=false
AI_BASE_URL="http://localhost:11434/v1"
AI_MODEL="gemma3:4b"
AI_API_KEY="not-needed"
AI_MAX_TOKENS=4096
AI_TEMPERATURE=0.3

# -----------------------------------------------------------------------------
# Notifications — SMTP (optional)
# -----------------------------------------------------------------------------
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""

# Notifications — Webhook (optional)
ALERT_WEBHOOK_URL=""

# Local/dev: skip background crons when true
DISABLE_CRON_JOBS=false

# -----------------------------------------------------------------------------
# Deployment mode & product licensing (enterprise / on-prem)
# -----------------------------------------------------------------------------
# saas (default) = multi-tenant NeurQ cloud
# onprem = customer-hosted; public signup off; product license required
DEPLOYMENT_MODE=saas
DISABLE_PUBLIC_SIGNUP=false

# Ed25519 keys (PEM). SaaS issuer needs PRIVATE; on-prem needs matching PUBLIC.
# Generate: node -e "const {generateKeyPairSync}=require('crypto');const k=generateKeyPairSync('ed25519');console.log(k.privateKey.export({type:'pkcs8',format:'pem'}).toString());console.log(k.publicKey.export({type:'spki',format:'pem'}).toString());"
LICENSE_PRIVATE_KEY=""
LICENSE_PUBLIC_KEY=""

# On-prem: NeurQ SaaS base for online activation (…/api/v1)
LICENSE_SERVER_URL=""

# On-prem first-boot (when DB has zero tenants)
ONPREM_ORG_NAME="Enterprise Organization"
OWNER_EMAIL="owner@localhost"
OWNER_PASSWORD="ChangeMe@123"
TENANT_ADMIN_EMAIL="admin@localhost"
TENANT_ADMIN_PASSWORD="ChangeMe@123"
INSTALL_ID=""
